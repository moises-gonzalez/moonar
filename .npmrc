# Supply-chain hardening
# In light of recent npm registry attacks, default to cautious settings.

# Block ALL postinstall / preinstall scripts globally.
# Playwright browsers install via the explicit `pnpm test:install` script,
# which calls `playwright install`. That bypass is intentional and visible.
ignore-scripts=true

# Don't pull in peers we didn't ask for; surface conflicts loudly.
auto-install-peers=false
strict-peer-dependencies=true

# Respect the "engines" field in package.json (Node + pnpm version pins).
engine-strict=true

# Prefer local store; fewer registry roundtrips.
prefer-offline=true

# NOTE: --frozen-lockfile is intentionally NOT set here.
# pnpm already defaults to frozen-lockfile in CI environments (CI=true).
# For local dev, the canonical command is `pnpm install --frozen-lockfile`
# (see README).  Forcing it in .npmrc would block the very first install,
# since the lockfile doesn't exist yet.
